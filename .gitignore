.superpowers/
.DS_Store
*.swp

# Xcode
*.xcuserstate
xcuserdata/
DerivedData/
*.xccheckout

# Swift PM
.build/
.swiftpm/xcode/

# Xcode project — generated by `xcodegen` from project.yml.
# project.yml is the source of truth.
*.xcodeproj/

# Generated by XcodeGen (Info.plist, .entitlements, etc. are generated)
Apps/*/Info.plist
Apps/*/*.entitlements

# Scratch / notes files often saved with cURL pastes that contain auth
# secrets. Never let these slip into git.
Apps/*/teams.swift
Apps/*/notes.swift
Apps/*/scratch.swift
Apps/*/*.notes
Apps/*/_scratch/*
dist/
dmg-staging/

# App Store archive output (xcarchive + signed .pkg). Regenerated by
# `xcodebuild archive` + `productbuild` — build artifacts only, no
# source. The signed .pkg is uploaded via `xcrun altool` then
# discarded.
build/
